# ============================================
# Application Settings
# ============================================
APP_NAME=Whisper WebApp
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ============================================
# Server Settings
# ============================================
HOST=0.0.0.0
PORT=8000

# ============================================
# Database Settings
# ============================================
DATABASE_URL=sqlite:///./data/whisper.db

# ============================================
# Whisper Settings
# ============================================
WHISPER_MODEL_DIR=~/.cache/whisper
DEFAULT_MODEL=base
DEFAULT_LANGUAGE=auto

# ============================================
# File Upload Settings
# ============================================
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=524288000
ALLOWED_EXTENSIONS=mp3,wav,m4a,flac,ogg,mp4,mkv,avi,mov,webm

# ============================================
# Storage Settings
# ============================================
TRANSCRIPTION_DIR=./data/transcriptions

# ============================================
# GPU Settings
# ============================================
USE_GPU=true

# ============================================
# Logging Settings
# ============================================
LOG_LEVEL=INFO

# ============================================
# CORS Settings
# ============================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000